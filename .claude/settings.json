{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f $(pwd)/.claude/CLAUDE.md && ln -sf ../AGENTS.md $(pwd)/.claude/CLAUDE.md"
          },
          {
            "type": "command",
            "command": "rm -f $(pwd)/.claude/skills && ln -sf ../.agents/skills $(pwd)/.claude/skills"
          }
        ]
      }
    ]
  }
}
